{
  "name": "aios-companion",
  "version": "0.15.0",
  "private": true,
  "type": "module",
  "description": "AIOS Companion \u2014 Conversation Manager + surface UI; consumes the AIOS control plane (ADR-0014)",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "companion": "./src/index.ts"
  },
  "scripts": {
    "companion": "node --experimental-strip-types ./src/index.ts",
    "surface": "concurrently -k -n api,ui -c teal,cyan \"pnpm surface:api\" \"pnpm surface:ui\"",
    "surface:api": "node --experimental-strip-types ./src/surface/server.ts",
    "surface:ui": "vite --config ui/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p ui/tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "smoke:mcp-http": "node --experimental-strip-types ./scripts/smoke-mcp-http.ts",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.9.2",
    "vite": "^7.0.4"
  }
}
