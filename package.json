{
  "name": "aios-companion",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "AIOS Companion — Conversation Manager; consome o control plane AIOS (ADR-0014)",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13"
